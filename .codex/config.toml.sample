[mcp_servers.shadcn]
# `apps/web/components.json` を参照させるため `--cwd apps/web` を付けています
command = "pnpm"
args = ["dlx", "shadcn@latest", "mcp", "--cwd", "apps/web"]

[mcp_servers.v0]
command = "npx"
args = [
  "mcp-remote",
  "https://mcp.v0.dev",
  "--header",
  "Authorization: Bearer ${V0_API_KEY}"
]
